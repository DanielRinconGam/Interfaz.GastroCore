{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./scr/components/*"],
      "@hooks/*": ["./scr/hooks/*"],
      "@services/*": ["./scr/Services/*"],
      "@css/*": ["./app/css/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}